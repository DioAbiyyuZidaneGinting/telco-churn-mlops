name: telco-churn-mlflow

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path:
        type: str
        default: "telco_churn_preprocessed.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 10
      test_size:
        type: float
        default: 0.2
    command: >
      python modelling.py
        --data_path {data_path}
        --n_estimators {n_estimators}
        --max_depth {max_depth}
        --test_size {test_size}
